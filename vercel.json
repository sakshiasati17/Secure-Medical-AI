{
    "version": 2,
    "builds": [
        {
            "src": "api/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/auth/(.*)",
            "dest": "api/main.py"
        },
        {
            "src": "/patients/(.*)",
            "dest": "api/main.py"
        },
        {
            "src": "/notes/(.*)",
            "dest": "api/main.py"
        },
        {
            "src": "/ai/(.*)",
            "dest": "api/main.py"
        },
        {
            "src": "/appointments/(.*)",
            "dest": "api/main.py"
        },
        {
            "src": "/health",
            "dest": "api/main.py"
        },
        {
            "src": "/docs",
            "dest": "api/main.py"
        },
        {
            "src": "/redoc",
            "dest": "api/main.py"
        },
        {
            "src": "/openapi.json",
            "dest": "api/main.py"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/$1",
            "check": true
        },
        {
            "src": "/(.*)",
            "status": 200,
            "dest": "/frontend/index.html"
        }
    ]
}